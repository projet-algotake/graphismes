#include <allegro.h>
#include <stdio.h>
#include <stdlib.h>
#include <math.h>

#define LARGEUR 800
#define HAUTEUR 600

#define HAUTEUR_INFO 70
#define SOL (SCREEN_H - HAUTEUR_INFO)

#define MAX_TIRS 20
#define MAX_BULLES 60

#define GRAVITE 0.25

typedef struct {
    int x;
    int y;
    int largeur;
    int hauteur;
    int vitesse;
} t_joueur;

typedef struct {
    int x;
    int y;
    int actif;
} t_tir;

typedef struct {
    float x;
    float y;
    float dx;
    float dy;
    int rayon;
    int taille;
    int actif;
} t_bulle;

typedef struct {
    char pseudo[30];
    int niveau;
    int score;
    int temps;
} t_partie;

BITMAP *page;

void initialisation_allegro() {
    allegro_init();
    install_keyboard();
    install_mouse();

    set_color_depth(desktop_color_depth());

    if (set_gfx_mode(GFX_AUTODETECT_WINDOWED, LARGEUR, HAUTEUR, 0, 0) != 0) {
        allegro_message("Probleme mode graphique");
        allegro_exit();
        exit(EXIT_FAILURE);
    }

    page = create_bitmap(SCREEN_W, SCREEN_H);
    if (!page) {
        allegro_message("Probleme creation buffer");
        allegro_exit();
        exit(EXIT_FAILURE);
    }
    set_window_title("Super Pang - ECE");
}

void initialiser_joueur(t_joueur *joueur) {
    joueur->largeur = 40;
    joueur->hauteur = 45;
    joueur->x = SCREEN_W / 2 - joueur->largeur / 2;
    joueur->y = SOL - joueur->hauteur;
    joueur->vitesse = 6;
}

void initialiser_tirs(t_tir tirs[]) {
    int i;
    for (i = 0; i < MAX_TIRS; i++) {
        tirs[i].actif = 0;
    }
}

void initialiser_bulles(t_bulle bulles[], int niveau) {
    int i;

    for (i = 0; i < MAX_BULLES; i++) {
        bulles[i].actif = 0;
    }

    for (i = 0; i < niveau + 1; i++) {
        bulles[i].x = 120 + i * 140;
        bulles[i].y = 120;
        bulles[i].dx = (i % 2 == 0) ? 3 + niveau : -3 - niveau;
        bulles[i].dy = -5;
        bulles[i].rayon = 35;
        bulles[i].taille = 3;
        bulles[i].actif = 1;
    }
}

void deplacer_joueur(t_joueur *joueur) {
    if (key[KEY_LEFT] && joueur->x > 0) {
        joueur->x -= joueur->vitesse;
    }

    if (key[KEY_RIGHT] && joueur->x + joueur->largeur < SCREEN_W) {
        joueur->x += joueur->vitesse;
    }
}

void tirer(t_joueur joueur, t_tir tirs[]) {
    int i;
    static int attente = 0;

    if (attente > 0) {
        attente--;
    }

    if (key[KEY_SPACE] && attente == 0) {
        for (i = 0; i < MAX_TIRS; i++) {
            if (!tirs[i].actif) {
                tirs[i].x = joueur.x + joueur.largeur / 2;
                tirs[i].y = joueur.y;
                tirs[i].actif = 1;
                attente = 15;
                break;
            }
        }
    }
}

void deplacer_tirs(t_tir tirs[]) {
    int i;

    for (i = 0; i < MAX_TIRS; i++) {
        if (tirs[i].actif) {
            tirs[i].y -= 10;

            if (tirs[i].y < 0) {
                tirs[i].actif = 0;
            }
        }
    }
}

void deplacer_bulles(t_bulle bulles[]) {
    int i;

    for (i = 0; i < MAX_BULLES; i++) {
        if (bulles[i].actif) {
            bulles[i].x += bulles[i].dx;
            bulles[i].y += bulles[i].dy;

            bulles[i].dy += GRAVITE;

            if (bulles[i].x - bulles[i].rayon < 0 ||
                bulles[i].x + bulles[i].rayon > SCREEN_W) {
                bulles[i].dx = -bulles[i].dx;
            }

            if (bulles[i].y + bulles[i].rayon > SOL) {
                bulles[i].y = SOL - bulles[i].rayon;
                bulles[i].dy = -bulles[i].dy * 0.85;
            }
        }
    }
}

int collision_cercle_rectangle(t_bulle bulle, t_joueur joueur) {
    int proche_x = bulle.x;
    int proche_y = bulle.y;

    if (proche_x < joueur.x) proche_x = joueur.x;
    if (proche_x > joueur.x + joueur.largeur) proche_x = joueur.x + joueur.largeur;

    if (proche_y < joueur.y) proche_y = joueur.y;
    if (proche_y > joueur.y + joueur.hauteur) proche_y = joueur.y + joueur.hauteur;

    int dx = bulle.x - proche_x;
    int dy = bulle.y - proche_y;

    return dx * dx + dy * dy <= bulle.rayon * bulle.rayon;
}

int collision_tir_bulle(t_tir tir, t_bulle bulle) {
    int dx = tir.x - bulle.x;
    int dy = tir.y - bulle.y;

    return dx * dx + dy * dy <= bulle.rayon * bulle.rayon;
}

void diviser_bulle(t_bulle bulles[], int indice) {
    int i;
    t_bulle ancienne = bulles[indice];

    bulles[indice].actif = 0;

    if (ancienne.taille <= 1) {
        return;
    }

    for (i = 0; i < MAX_BULLES; i++) {
        if (!bulles[i].actif) {
            bulles[i].x = ancienne.x;
            bulles[i].y = ancienne.y;
            bulles[i].rayon = ancienne.rayon / 2;
            bulles[i].taille = ancienne.taille - 1;
            bulles[i].dx = -4;
            bulles[i].dy = -6;
            bulles[i].actif = 1;
            break;
        }
    }

    for (i = 0; i < MAX_BULLES; i++) {
        if (!bulles[i].actif) {
            bulles[i].x = ancienne.x;
            bulles[i].y = ancienne.y;
            bulles[i].rayon = ancienne.rayon / 2;
            bulles[i].taille = ancienne.taille - 1;
            bulles[i].dx = 4;
            bulles[i].dy = -6;
            bulles[i].actif = 1;
            break;
        }
    }
}

void gerer_collisions(t_partie *partie, t_joueur joueur, t_tir tirs[],
                      t_bulle bulles[], int *niveau_perdu) {
    int i, j;

    for (i = 0; i < MAX_BULLES; i++) {
        if (bulles[i].actif && collision_cercle_rectangle(bulles[i], joueur)) {
            *niveau_perdu = 1;
        }
    }

    for (i = 0; i < MAX_TIRS; i++) {
        if (tirs[i].actif) {
            for (j = 0; j < MAX_BULLES; j++) {
                if (bulles[j].actif && collision_tir_bulle(tirs[i], bulles[j])) {
                    tirs[i].actif = 0;
                    partie->score += 100;
                    diviser_bulle(bulles, j);
                    break;
                }
            }
        }
    }
}

int toutes_bulles_detruites(t_bulle bulles[]) {
    int i;

    for (i = 0; i < MAX_BULLES; i++) {
        if (bulles[i].actif) {
            return 0;
        }
    }

    return 1;
}

// === GRAPHISMES DU JEU AMELIORES ===
void afficher_jeu(t_partie partie, t_joueur joueur, t_tir tirs[], t_bulle bulles[]) {
    int i;

    // Fond du jeu : Ciel de nuit stylé
    clear_to_color(page, makecol(15, 25, 45));

    // Le sol (Zone d'interface)
    rectfill(page, 0, SOL, SCREEN_W, SCREEN_H, makecol(20, 20, 20));
    // Ligne de séparation style "Néon" entre le jeu et l'interface
    line(page, 0, SOL, SCREEN_W, SOL, makecol(0, 255, 255));

    // Interface textuelle
    textprintf_ex(page, font, 20, SOL + 25, makecol(255, 255, 255), -1,
                  "Pseudo : %s", partie.pseudo);
    textprintf_ex(page, font, 220, SOL + 25, makecol(0, 255, 0), -1,
                  "Niveau : %d", partie.niveau);
    textprintf_ex(page, font, 380, SOL + 25, makecol(255, 255, 0), -1,
                  "Score : %d", partie.score);
    textprintf_ex(page, font, 560, SOL + 25, makecol(255, 100, 100), -1,
                  "Temps : %d", partie.temps);

    // Dessin du joueur (avec un petit effet de "bords")
    rectfill(page, joueur.x, joueur.y, joueur.x + joueur.largeur, joueur.y + joueur.hauteur, makecol(0, 150, 255));
    rect(page, joueur.x, joueur.y, joueur.x + joueur.largeur, joueur.y + joueur.hauteur, makecol(255, 255, 255));

    // Dessin des tirs (plus visibles)
    for (i = 0; i < MAX_TIRS; i++) {
        if (tirs[i].actif) {
            rectfill(page, tirs[i].x - 2, tirs[i].y - 20, tirs[i].x + 2, tirs[i].y, makecol(255, 255, 0));
        }
    }

    // Dessin des bulles (avec un petit reflet)
    for (i = 0; i < MAX_BULLES; i++) {
        if (bulles[i].actif) {
            circlefill(page, bulles[i].x, bulles[i].y, bulles[i].rayon, makecol(220, 20, 60)); // Rouge profond
            circle(page, bulles[i].x, bulles[i].y, bulles[i].rayon, makecol(255, 255, 255));    // Contour blanc
            // Petit reflet pour faire "Bulle"
            circlefill(page, bulles[i].x - bulles[i].rayon/3, bulles[i].y - bulles[i].rayon/3, bulles[i].rayon/4, makecol(255, 150, 150));
        }
    }

    blit(page, screen, 0, 0, 0, 0, SCREEN_W, SCREEN_H);
}

// === NOUVEAU MENU DYNAMIQUE ===
int menu() {
    int selection = 1;
    int frame = 0;

    while (!key[KEY_ESC]) {
        // Fond bleu nuit cohérent avec le jeu
        clear_to_color(page, makecol(10, 20, 40));

        // Animation de bulles en fond pour la décoration
        for(int i = 0; i < 6; i++) {
            int bx = (frame + i * 150) % SCREEN_W;
            int by = 300 + (int)(sin((frame + i * 50) * 0.05) * 100);
            circle(page, bx, by, 20 + i * 5, makecol(0, 100 + i * 20, 255));
        }

        // Titre avec ombre
        textout_centre_ex(page, font, "=== SUPER BULLES ===", (SCREEN_W / 2) + 3, 103, makecol(150, 0, 0), -1);
        textout_centre_ex(page, font, "=== SUPER BULLES ===", SCREEN_W / 2, 100, makecol(255, 255, 0), -1);

        // Couleurs de sélection
        int couleur1 = (selection == 1) ? makecol(0, 255, 0) : makecol(150, 150, 150);
        int couleur2 = (selection == 2) ? makecol(0, 255, 0) : makecol(150, 150, 150);
        int couleur3 = (selection == 3) ? makecol(0, 255, 0) : makecol(150, 150, 150);

        // Textes du menu
        if (selection == 1) textout_ex(page, font, "->", 300, 230, couleur1, -1);
        textout_centre_ex(page, font, "Nouvelle partie", SCREEN_W / 2, 230, couleur1, -1);

        if (selection == 2) textout_ex(page, font, "->", 300, 270, couleur2, -1);
        textout_centre_ex(page, font, "Regles", SCREEN_W / 2, 270, couleur2, -1);

        if (selection == 3) textout_ex(page, font, "->", 300, 310, couleur3, -1);
        textout_centre_ex(page, font, "Quitter", SCREEN_W / 2, 310, couleur3, -1);

        textout_centre_ex(page, font, "Utilisez les fleches HAUT/BAS et validez avec ENTREE", SCREEN_W / 2, 500, makecol(100, 150, 200), -1);

        blit(page, screen, 0, 0, 0, 0, SCREEN_W, SCREEN_H);

        // Navigation clavier
        if (key[KEY_UP]) {
            selection--;
            if (selection < 1) selection = 3;
            rest(150);
        }

        if (key[KEY_DOWN]) {
            selection++;
            if (selection > 3) selection = 1;
            rest(150);
        }

        if (key[KEY_ENTER]) {
            clear_keybuf();
            return selection;
        }

        frame++;
        rest(20);
    }

    return 3;
}

// === REGLES AMELIOREES ===
void afficher_regles() {
    clear_to_color(page, makecol(10, 20, 40));

    // Décorations graphiques
    rectfill(page, 40, 40, SCREEN_W - 40, SCREEN_H - 40, makecol(20, 30, 60));
    rect(page, 40, 40, SCREEN_W - 40, SCREEN_H - 40, makecol(0, 255, 255));

    textout_centre_ex(page, font, "--- REGLES DU JEU ---", SCREEN_W / 2, 80, makecol(255, 255, 0), -1);

    textout_ex(page, font, "* Fleches GAUCHE / DROITE : Deplacer le joueur", 100, 160, makecol(255, 255, 255), -1);
    textout_ex(page, font, "* Touche ESPACE : Tirer un harpon vers le haut", 100, 200, makecol(255, 255, 255), -1);

    textout_ex(page, font, "OBJECTIF : Detruire toutes les bulles avant la fin du temps imparti !", 100, 280, makecol(0, 255, 0), -1);
    textout_ex(page, font, "ATTENTION : Si une bulle touche le joueur, la partie est perdue.", 100, 320, makecol(255, 100, 100), -1);

    textout_centre_ex(page, font, "Appuyez sur une touche pour revenir au menu...", SCREEN_W / 2, 450, makecol(150, 150, 150), -1);

    blit(page, screen, 0, 0, 0, 0, SCREEN_W, SCREEN_H);

    readkey();
    clear_keybuf();
}

void jouer_niveau(t_partie *partie) {
    t_joueur joueur;
    t_tir tirs[MAX_TIRS];
    t_bulle bulles[MAX_BULLES];

    int niveau_perdu = 0;
    int compteur_temps = 0;

    initialiser_joueur(&joueur);
    initialiser_tirs(tirs);
    initialiser_bulles(bulles, partie->niveau);

    partie->temps = 60;

    while (!key[KEY_ESC] && !niveau_perdu && !toutes_bulles_detruites(bulles)) {
        deplacer_joueur(&joueur);
        tirer(joueur, tirs);
        deplacer_tirs(tirs);
        deplacer_bulles(bulles);
        gerer_collisions(partie, joueur, tirs, bulles, &niveau_perdu);

        compteur_temps++;
        if (compteur_temps >= 50) {
            partie->temps--;
            compteur_temps = 0;
        }

        if (partie->temps <= 0) {
            niveau_perdu = 1;
        }

        afficher_jeu(*partie, joueur, tirs, bulles);

        rest(20);
    }

    clear_to_color(page, makecol(0, 0, 0));

    if (niveau_perdu) {
        textout_centre_ex(page, font, "NIVEAU PERDU", SCREEN_W / 2, 250,
                          makecol(255, 0, 0), -1);
    } else {
        textout_centre_ex(page, font, "NIVEAU GAGNE !", SCREEN_W / 2, 250,
                          makecol(0, 255, 0), -1);
        partie->score += partie->temps * 10;
        partie->niveau++;
    }

    textout_centre_ex(page, font, "Appuyez sur une touche pour continuer",
                      SCREEN_W / 2, 300, makecol(255, 255, 255), -1);

    blit(page, screen, 0, 0, 0, 0, SCREEN_W, SCREEN_H);

    readkey();
    clear_keybuf();
}

int main() {
    t_partie partie;
    int choix;
    int quitter = 0;

    initialisation_allegro();

    while (!quitter) {
        choix = menu();

        if (choix == 1) {
            // CORRECTION DU FREEZE ICI :
            // On attribue un nom par défaut au lieu de bloquer le jeu avec un scanf
            sprintf(partie.pseudo, "Joueur 1");

            partie.niveau = 1;
            partie.score = 0;

            jouer_niveau(&partie);
        } else if (choix == 2) {
            afficher_regles();
        } else if (choix == 3) {
            quitter = 1;
        }
    }

    destroy_bitmap(page);
    allegro_exit();

    return 0;
}
END_OF_MAIN();
